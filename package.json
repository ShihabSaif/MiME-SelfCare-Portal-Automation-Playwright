  "main": "index.js",
  "scripts": {
    "test:flow": "playwright test --workers=1 --headed",
    "test:flow:report": "node utils/run-and-open-chrome-report.js npx playwright test --workers=1 --headed",
    "test:login": "playwright test tests/myportal-login.spec.ts --project=login",
