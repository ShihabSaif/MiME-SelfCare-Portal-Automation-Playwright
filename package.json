    "test:recharge:report": "node utils/run-and-open-chrome-report.js npx playwright test tests/recharge-wallet.spec.ts --project=recharge-wallet --workers=1 --headed",
    "test:recharge": "playwright test tests/recharge-wallet.spec.ts --project=recharge-wallet --workers=1 --headed",
    "test:my-profile": "playwright test tests/my-profile.spec.ts -c playwright.isolated.config.ts --workers=1 --headed"
  },
